# CONST-053 .gitignore mandate (cascaded from constitution submodule §11.4.30)
# Round-263 expansion — comprehensive coverage of forbidden classes.

# --- 1. Build artefacts ---
/bin/
/build/
/dist/
/out/
target/
*.exe
*.dll
*.so
*.dylib
*.a
*.o
*.class
*.pyc
*.test
*.out

# --- 2. Cache files ---
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/
node_modules/
.next/
.cache/
.gradle/
.terraform/

# --- 3. Temp files ---
*.tmp
*.swp
*~
.DS_Store
Thumbs.db
*.orig
*.rej

# --- 4. Sensitive-data files (CONST-042 intersection) ---
# Only .env.example placeholder is allowed.
.env
.env.*
!.env.example
*.pem
*.key
*.crt
id_rsa*
id_ed25519*
.netrc
secrets/
api_keys.sh

# --- 5. Generated reports / logs / coverage ---
*.log
coverage.out
coverage.html
htmlcov/

# --- 6. OS / IDE personal state ---
.idea/
.history/
.vscode/

# --- 7. Local vendor caches (Go) ---
/vendor/
